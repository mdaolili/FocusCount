# 忽略 node_modules 依赖目录
node_modules/

# 忽略构建输出目录
dist/
unpackage/

# 忽略本地环境配置
.env.local
.env.*.local

# 忽略编辑器配置和系统文件
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# 忽略日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 忽略包管理锁文件（可选，团队协作建议保留）
package-lock.json
# yarn.lock
# pnpm-lock.yaml
